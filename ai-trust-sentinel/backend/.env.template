# ── API Keys ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values. Never commit .env!

# OpenAI — platform.openai.com → API keys → Create new secret key
# Make sure billing is set up — the key won't work without credits loaded
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Google AI Studio — aistudio.google.com → Get API key (free)
GEMINI_API_KEY=AIzaSyYOUR_KEY_HERE

# Tavily — tavily.com → Dashboard → API Keys (free 1,000 calls/month)
TAVILY_API_KEY=tvly-YOUR_KEY_HERE

# Upstash Redis — upstash.com → Create database → Copy REST URL
# IMPORTANT: Must start with rediss:// (double s) — won't work with redis://
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_DB.upstash.io:6379

# ── Tunable Parameters ───────────────────────────────────────────────────────
# Queries with confidence below this threshold will trigger Gemini verification
CONFIDENCE_THRESHOLD=75

# How long to cache results (in seconds). 3600 = 1 hour
CACHE_TTL_SECONDS=3600

# Maximum number of claims to extract from any answer
MAX_CLAIMS=5

# Maximum number of Tavily search results per claim
MAX_TAVILY_RESULTS=3
