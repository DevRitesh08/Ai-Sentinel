# Copy this file to .env and fill in the values you want to use locally.
# Never commit backend/.env.

# API keys
# OpenAI powers claim extraction. If omitted, the extractor falls back to the full answer.
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Gemini powers the primary answer, verifier, bias scan, and intent checks.
GEMINI_API_KEY=AIzaSyYOUR_KEY_HERE

# Tavily powers live web fact-checking. If omitted, claims are marked UNCERTAIN.
TAVILY_API_KEY=tvly-YOUR_KEY_HERE

# Redis is optional. If omitted, caching is disabled.
# IMPORTANT: Upstash URLs must start with rediss://
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_DB.upstash.io:6379

# Model configuration
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_VERIFIER_MODEL=gemini-2.5-pro
OLLAMA_PRIMARY_MODEL=llama3
OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# Tunable parameters
CONFIDENCE_THRESHOLD=75
CACHE_TTL_SECONDS=3600
MAX_CLAIMS=5
MAX_TAVILY_RESULTS=3
OFFLINE_MODE=false
